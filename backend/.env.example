# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/stock_analysis_db
# DATABASE_USER=root
# DATABASE_PASSWORD=your_password
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_NAME=stock_analysis_db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
API_VERSION=v1
API_PORT=8000
API_HOST=0.0.0.0

# LLM Configuration
# LLM_PROVIDER options: openai, aliyun, baidu, zhipu, local
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key
# Aliyun DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key
# Baidu ERNIE API Key
BAIDU_API_KEY=your_baidu_api_key
# Zhipu GLM API Key
ZHIPU_API_KEY=your_zhipu_api_key

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Data Configuration
DATA_RETENTION_DAYS=30
CACHE_TTL_HOURS=24
ANALYSIS_TIMEOUT_SECONDS=60

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Task Scheduler
SCHEDULER_ENABLED=true
TASK_EXECUTION_TIMEOUT=300

# Stock Market Trading Hours (for Chinese market)
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=15:00
